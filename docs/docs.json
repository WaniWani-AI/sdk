  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.waniwani.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://app.waniwani.ai"
    }
  },
  "contextual": {
    "options": ["copy"],
    "display": "header"
  },
  "footer": {
    "socials": {
      "github": "https://github.com/waniwani-ai",
      "website": "https://waniwani.ai"
    }
