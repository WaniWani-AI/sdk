          },
          {
            "group": "Build a funnel",
            "pages": [
              "funnels/overview",
              "funnels/sales-funnel",
              "funnels/lead-generation",
              "funnels/booking",
              "funnels/insurance-quote"
            ]
          },
          {
            "group": "Flow engine",
            "pages": [
              "flows/overview",
              "flows/nodes",
              "flows/edges",
              "flows/interrupts",
              "flows/state",
              "flows/register",
              "flows/examples"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "deployment/overview"
            ]
          },
          {
            "group": "Persistence",
            "pages": [
              "flows/kv-store",
              "flows/self-hosting"
            ]
          },
          {
            "group": "Tracking & analytics",
            "pages": [
              "tracking/overview",
              "tracking/events",
              "tracking/sessions",
              "tracking/identify"
            ]
          },
          {
            "group": "Knowledge base",
            "pages": [
              "knowledge-base/overview"
            ]
          },
          {
            "group": "Chat widget",
            "pages": [
              "chat/embed",
              "chat/react"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "configuration/wrap-server",
              "configuration/environment-variables",
              "configuration/security"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/tiers",
              "reference/entry-points",
              "reference/kv-store-api",
              "reference/event-schema",
              "reference/flow-tool-contract",
              "migration"
            ]
          },
          {
            "group": "Skills & commands",
            "pages": [
              "guides/skills",
              "guides/commands"
            ]
          }
        ]
      }
    ]
  },
  "redirects": [
    { "source": "/legacy/tools-resources", "destination": "/reference/tiers" },
    { "source": "/legacy/widget-hooks", "destination": "/reference/tiers" },
    { "source": "/legacy/chat-adapters", "destination": "/chat/react" },
    { "source": "/legacy/evals", "destination": "/reference/tiers" }
