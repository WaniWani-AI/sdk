{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "WaniWani SDK",
  "colors": {
    "primary": "#03d916",
    "light": "#5EFF73",
    "dark": "#02A811"
  },
  "background": {
